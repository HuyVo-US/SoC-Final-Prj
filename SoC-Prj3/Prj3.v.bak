module Prj3 (
	input					CLOCK_50,
	input		[0:0]		KEY,
	input		[9:0]		SW,
	output	[6:0]		HEX0, HEX1, HEX2, HEX3, HEX4, HEX5
);

	system NIOS_system (
		.clk_clk								(CLOCK_50),
		.hexs_0_conduit_end_hex0		(HEX0),
		.hexs_0_conduit_end_hex1		(HEX1),
		.hexs_0_conduit_end_hex2		(HEX2),
		.hexs_0_conduit_end_hex3		(HEX3),
		.hexs_0_conduit_end_hex4		(HEX4),
		.hexs_0_conduit_end_hex5		(HEX5),
		.reset_reset_n								(KEY[0]),
		.switches_0_conduit_end_export	({22'd0,SW})
	);
endmodule
