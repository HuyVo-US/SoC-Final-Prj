	component system is
		port (
			clk_clk                       : in  std_logic                     := 'X';             -- clk
			hexs_0_conduit_end_hex0       : out std_logic_vector(6 downto 0);                     -- hex0
			hexs_0_conduit_end_hex1       : out std_logic_vector(6 downto 0);                     -- hex1
			hexs_0_conduit_end_hex2       : out std_logic_vector(6 downto 0);                     -- hex2
			hexs_0_conduit_end_hex3       : out std_logic_vector(6 downto 0);                     -- hex3
			hexs_0_conduit_end_hex4       : out std_logic_vector(6 downto 0);                     -- hex4
			hexs_0_conduit_end_hex5       : out std_logic_vector(6 downto 0);                     -- hex5
			reset_reset_n                 : in  std_logic                     := 'X';             -- reset_n
			switches_0_conduit_end_export : in  std_logic_vector(31 downto 0) := (others => 'X')  -- export
		);
	end component system;

