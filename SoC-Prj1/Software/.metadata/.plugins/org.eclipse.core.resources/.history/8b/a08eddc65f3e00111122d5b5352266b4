#include <stdio.h>
#include "io.h"
#include "system.h"

void delay_1s() {
    for (volatile int i = 0; i < 5000000; i++);
}

unsigned char seg7[10] = {
    0b1000000, // 0
    0b1111001, // 1
    0b0100100, // 2
    0b0110000, // 3
    0b0011001, // 4
    0b0010010, // 5
    0b0000010, // 6
    0b1111000, // 7
    0b0000000, // 8
    0b0010000  // 9
};

int main() {

    int hour = 0, min = 0, sec = 0;

    while (1) {

        int sw = IORD(SWITCH_BASE, 0);

        int mode = (sw >> 8) & 0x3;
        int tens = (sw >> 4) & 0xF;
        int unit = sw & 0xF;

        int value = tens * 10 + unit;

        // ===== SET MODE =====
        if (mode == 0) { // sec
            if (tens < 6 && unit < 10)
                sec = value;
        }
        else if (mode == 1) { // min
            if (tens < 6 && unit < 10)
                min = value;
        }
        else if (mode == 2) { // hour
            if (tens < 3 && unit < 10) {
                if (tens == 2 && unit > 3)
                    hour = 23;
                else
                    hour = value;
            }
        }
        else if (mode == 3) { // RUN
            delay_1s();

            sec++;
            if (sec >= 60) {
                sec = 0;
                min++;
            }
            if (min >= 60) {
                min = 0;
                hour++;
            }
            if (hour >= 24) {
                hour = 0;
            }
        }

        int h_t = hour / 10;
        int h_u = hour % 10;

        int m_t = min / 10;
        int m_u = min % 10;

        int s_t = sec / 10;
        int s_u = sec % 10;

        IOWR(HEX0_BASE, 0, seg7[s_u]);
        IOWR(HEX1_BASE, 0, seg7[s_t]);
        IOWR(HEX2_BASE, 0, seg7[m_u]);
        IOWR(HEX3_BASE, 0, seg7[m_t]);
        IOWR(HEX4_BASE, 0, seg7[h_u]);
        IOWR(HEX5_BASE, 0, seg7[h_t]);
    }

    return 0;
}



